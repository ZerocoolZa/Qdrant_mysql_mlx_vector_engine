digraph Web {
    rankdir=TB;
    node [shape=box, style=filled, fillcolor=lightblue];
    "Web" [shape=box, style=filled, fillcolor=lightgreen, fontsize=16];

    "Web" -> "Browser";
    "Web" -> "Request";
    "Web" -> "Response";
    "Web" -> "Session";
    "Web" -> "Cookie";
    "Web" -> "Header";
    "Web" -> "URL";
    "Web" -> "HTTP";
    "Web" -> "HTTPS";
    "Web" -> "Download";
    "Web" -> "Upload";
    "Web" -> "Cache";
    "Web" -> "Parser";
    "Web" -> "Scraper";
    "Web" -> "Crawler";
    "Web" -> "Spider";
    "Web" -> "Auth";
    "Web" -> "Proxy";
    "Web" -> "DNS";
    "Web" -> "SSL";
    "Web" -> "RateLimiter";
    "Web" -> "Retry";
    "Web" -> "Redirect";
    "Web" -> "Compression";
    "Web" -> "Robots";
    "Web" -> "Monitor";
    "Web" -> "Security";
    "Web" -> "Validator";
    "Browser" -> "Request" [label="USES", style=dashed, color=gray];
    "Browser" -> "Response" [label="USES", style=dashed, color=gray];
    "Browser" -> "Cookie" [label="USES", style=dashed, color=gray];
    "Browser" -> "Session" [label="USES", style=dashed, color=gray];
    "Browser" -> "Cache" [label="USES", style=dashed, color=gray];
    "Browser" -> "Parser" [label="USES", style=dashed, color=gray];
    "Request" -> "Header" [label="USES", style=dashed, color=gray];
    "Request" -> "Auth" [label="USES", style=dashed, color=gray];
    "Request" -> "URL" [label="USES", style=dashed, color=gray];
    "Request" -> "Cookie" [label="FEEDS", style=dashed, color=gray];
    "Request" -> "HTTP" [label="TRIGGERS", style=dashed, color=gray];
    "Request" -> "HTTPS" [label="TRIGGERS", style=dashed, color=gray];
    "HTTP" -> "Response" [label="FEEDS", style=dashed, color=gray];
    "HTTPS" -> "Response" [label="FEEDS", style=dashed, color=gray];
    "Response" -> "Parser" [label="FEEDS", style=dashed, color=gray];
    "Response" -> "Cache" [label="FEEDS", style=dashed, color=gray];
    "Scraper" -> "Request" [label="USES", style=dashed, color=gray];
    "Scraper" -> "Parser" [label="USES", style=dashed, color=gray];
    "Scraper" -> "Download" [label="USES", style=dashed, color=gray];
    "Crawler" -> "Scraper" [label="WRAPS", style=dashed, color=gray];
    "Crawler" -> "Robots" [label="USES", style=dashed, color=gray];
    "Crawler" -> "RateLimiter" [label="USES", style=dashed, color=gray];
    "Spider" -> "Crawler" [label="WRAPS", style=dashed, color=gray];
    "Spider" -> "Cache" [label="USES", style=dashed, color=gray];
    "Download" -> "Retry" [label="USES", style=dashed, color=gray];
    "Download" -> "Redirect" [label="USES", style=dashed, color=gray];
    "Upload" -> "Retry" [label="USES", style=dashed, color=gray];
    "Auth" -> "SSL" [label="ENABLES", style=dashed, color=gray];
    "Proxy" -> "HTTP" [label="WRAPS", style=dashed, color=gray];
    "Proxy" -> "HTTPS" [label="WRAPS", style=dashed, color=gray];
    "DNS" -> "URL" [label="FEEDS", style=dashed, color=gray];
    "Monitor" -> "Validator" [label="MEASURES", style=dashed, color=gray];
    "Security" -> "Validator" [label="USES", style=dashed, color=gray];
    "Compression" -> "HTTP" [label="ENABLES", style=dashed, color=gray];
    "Web" -> "Run" [label="dispatch", style=dashed];
}