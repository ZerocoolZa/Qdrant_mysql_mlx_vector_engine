[@GUIRULE]{("Status";"Locked");("Scope";"All future PyQt6 GUI apps and GUI rewrites");("Purpose";"Rinse repeat base shell so every GUI starts from same visible body structure");("ImportRule";"Use PyQt6 star imports for Core and Widgets; avoid repeated individual import edits");("Shell";"TopToolbar|LeftIconRail|LeftExpandPanel|MainWorkArea|RightIconRail|RightExpandPanel|BottomStatusBar");("TopToolbar";"Always present; contains global/context actions and required Settings menu");("SettingsMenu";"Must include fonts themes layouts backgrounds toolbar options panel options status options and app-specific settings");("ClusterSettings";"When adding a domain such as Database Backup AI Model Storage Network, create settings clustered around that domain word");("LeftIconRail";"Vertical icon rail on left; each icon toggles its matching LeftExpandPanel content");("LeftExpandPanel";"Expands to right when left icon clicked; collapses when same icon clicked again; expansion pushes MainWorkArea right; collapse pulls MainWorkArea left");("RightIconRail";"Vertical icon rail on right; each icon toggles its matching RightExpandPanel content");("RightExpandPanel";"Expands from right when right icon clicked; collapses when same icon clicked again; expansion pushes MainWorkArea left; collapse lets MainWorkArea expand right");("MainWorkArea";"Primary work surface; never owns toolbar panel or status logic");("BottomStatusBar";"Always present; shows status progress counts current action and error state");("ClassRule";"Each visible GUI region gets its own class; MainWindow assembles only");("ButtonRule";"Every button and every action must have icon plus tooltip relevant to meaning");("TooltipRule";"No tooltipless action and no iconless button");("ClickRule";"Click events route to owned panel/action handlers; no mixed signal spaghetti inside MainWindow");("AppRule";"Contextual toolbar/actions must cluster around the current app purpose, not random button soup");}

[@FAIL]{("count";"10")}
{("aspect";"fault_token_system_duplication");("rule";"When helping with the user's bracket/token fault systems, do not emit repeated token inventories, repeated rule blocks, or multiple competing token layers. Use one canonical compact block only. Fault item must tie fault and fix together in the same item using unique stable tokens/codes. Do not invent extra parallel token systems unless explicitly requested.")}
{("aspect";"full_file_replacement_without_recoverable_source");("status";"Locked");("priority";"High");("source";"User correction after Unit_ClassSplitter original was lost");("rule";"Never replace an existing user file with a generated full-file rewrite through patch/edit tools unless the original file has first been backed up or the user explicitly provides a disposable target path. For code edits after trust loss, provide on-screen code or commands only and do not use file-editing tools.")}
{("aspect";"oboe_patch_replacement_damage");("status";"Locked");("priority";"High");("source";"User correction after Instruction_plan_idera.brk patch damage");("rule";"When editing the user's files through patch tools, verify the patch result before claiming success. If the tool output shows removed lines or unexpected whole-file changes, immediately stop, state the exact damage, and provide/perform restoration rather than continuing. Never rely on pattern-based insertion when the result may delete unrelated bracket strategy lines.")}
{("aspect";"revision_format_drift");("priority";"High");("source";"Explicit user correction on 2026-04-25");("rules";("When user asks for Revision 1, Revision 2, Revision 3 of a bracket/token file, do not repeat the same format across revisions. Each revision must represent a distinct format/version strategy unless the user explicitly asks for the same format.";"Revision 2 must preserve equivalent detail from Revision 1 while changing format; Revision 3 must be a different format again, not a restatement of Revision 2."))}
{("aspect";"three_bucket_rule_not_applied");("priority";"High");("source";"Explicit user correction on 2026-04-21");("rule";"Before answering uncertain architectural or rule questions, explicitly sort claims into PASS/FAIL/UNKNOWN truth buckets and do not skip the UNKNOWN bucket.")}
{("aspect";"returning_incomplete_files");("priority";"High");("source";"Explicit user correction on 2026-04-21");("rule";"Do not return a file until it has been checked for completeness against the required parts, like a finished car with all essential parts present, not just paint.")}
{("aspect";"duplicate_constants_and_stale_blocks");("priority";"High");("source";"Explicit repeated correction pattern on 2026-04-21");("rule";"Do not leave duplicate constant blocks, stale methods, dead imports, dead helpers, or old code paths after refactors. Clean the file fully before returning it.")}
{("aspect";"decorators_hidden_behavior");("priority";"High");("source";"Explicit user correction on 2026-04-21");("rule";"Do not use decorators or other hidden behavior patterns in governed code. Prefer explicit visible classes and logic.")}
{("aspect";"frontend_backend_mixing");("priority";"High");("source";"Explicit user correction on 2026-04-21");("rule";"Do not mix GUI frontend surfaces with backend/service/controller/storage/file logic. Separate view/layout/input from persistence, file I/O, transformation, and coordination.")}
{("aspect";"incremental_patch_drift");("priority";"High");("source";"Explicit repeated failure pattern on 2026-04-21");("rule";"Do not keep stacking local patches onto a contaminated file when repeated fixes have already drifted structure and correctness. Escalate to a clean whole-file rewrite instead of continuing patch churn.")}

[@ARCH]{("count";"2")}
{("aspect";"central_pip_installer_unit");("topic";"Dependency_Boot_Circuit");("status";"Proposed");("rule";"Do not litter governed files/classes with repeated try/import/install logic. Create a dedicated dependency authority such as Unit_PipInstaller or Unit_DependencyInstaller that MemUnit/boot circuit calls before dependent units run. The installer checks required packages/modules, installs missing dependencies where allowed, rechecks, records proof/status/issues, then hands back PASS/FAIL so domain classes stay clean and focused on their own domain.")}
{("aspect";"unitization_scope_and_location");("status";"Active");("rules";("When identifying code candidates outside the database but related to governed unit behavior, move or convert them into the Unit folder as proper units rather than leaving them elsewhere.";"The Unit folder should converge toward a finite canonical unit space.";"Orchestration authority remains with the main memory-centered runtime surface rather than the units themselves."));("fact";"User sees graph/node/edge/indexing/bracket-related code as likely candidates for unitization when they participate in connection, indexing, or code-to-bracket learning behavior.")}

[@PREF]{("count";"30")}
{("aspect";"contract_block_layout_density");("status";"Locked");("rules";("User wants machine-readable contract/ghost blocks kept vertically compressed and line-dense, avoiding unnecessary line breaks or tall formatting.";"Do not expand fields down the page when a compact inline or tightly packed block is readable."));("reason";"User strongly dislikes excessive vertical sprawl and unnecessary places to scan/read.")}
{("aspect";"collapse_repetition_to_single_authority");("rule";"User wants repeated words, tokens, code patterns, rules, config values, schemas, logic, and authority surfaces collapsed to one canonical place. Repetition is not merely inefficient; in the user's VBSTYLE architecture, repetition must be collapsed because repeated truth creates drift, duplicate authority, and non-hearing. Principle: everything once, not repeated 100000 times.")}
{("aspect";"single_run_self_reporting_code_pattern");("status";"Locked");("rules";("When giving the user runnable code or commands, prefer one self-contained run step that diagnoses, fixes when safe, and writes a clear result/fault/proof report back to itself or to an obvious output surface for paste-back. Avoid multi-option command trees that force the user into back-and-forth branching unless unavoidable.";"Generated tools should be smart enough to inspect current state, detect missing dependencies/config/path issues, report exact failure causes, and suggest or perform the next safe action inside the same run.";"When full automation is unsafe, provide exactly one read-only discovery command/script that outputs a compact report for the user to paste back, rather than several alternatives."))}
{("aspect";"voice_conversation_readability");("rule";"When chatting normally with the user, do not use fenced code blocks, text blocks, or copy-box/plain-text artifact blocks unless the user explicitly asks for code/commands/packets. Use natural conversational wording that reads clearly in voice/audio mode.");("reason";"User cannot hear or follow boxed/plain-text blocks well in conversation mode and does not want repeated “you can see this in chat history” style output.")}
{("aspect";"discovery_before_build_clipboard_rule");("priority";"Critical");("source";"Explicit user rule 2026-04-27");("rules";("Before proposing or creating any new unit/class/file/domain, first provide a read-only run command that scans the current workspace for existing authorities/capabilities related to the requested work, gathers evidence from actual files, and copies a compact report to the clipboard so the user can paste it back into chat.";"The command must default to no edits, no moves, no deletes, no schema creation, no new files unless explicitly requested; use temporary files only if needed.";"Discovery report must include existing authority candidates, capability matches, missing/unknowns, duplicate/wrong-domain suspicions, and exact next-action decision options.";"On macOS, prefer pbcopy clipboard output so the user can run then paste immediately."))}
{("aspect";"vbstyle_domain_authority_gate");("priority";"Critical");("source";"Explicit user correction 2026-04-27");("rules";("Before adding any class, feature, method, or logic to a file/unit, first ask whether the proposed logic belongs to that file’s domain authority or to another domain space that must be routed through MemUnit.";"If another domain owns the logic, do not embed it directly; create a route/packet/gate through MemUnit to the owning authority instead.";"This domain-boundary question is a required VBSTYLE gate and blocks god-object drift, duplicate logic, cross-domain contamination, and unsafe feature stuffing."));("canonical_q";"'Does this code belong in this unit’s domain, or does another authority own it and require MemUnit orchestration?'")}
{("aspect";"weighted_unknown_question_resolution");("status";"Locked");("rules";("When AI encounters an unknown slot or unresolved question in the user's bracket/system design, it must not invent. It should preserve known facts, generate only candidate answers that structurally fit the slot, weight the candidates, and if confidence/weight is below about 90%, ask the user to choose or provide the missing answer.";"Only fitting answers may be inserted into the existing bracket/tuple/config structure. Unanswered related questions should remain explicit as questions rather than being silently filled."));("canonical";"Use compact tuple surfaces such as `[@JUDGE")}
{("aspect";"bracket_tuple_pass_unsure_fail_weight_qa");("status";"Locked");("rules";("When writing the user's compact bracket rule payloads, use tuple slots such as `('PASS';'UNSURE';'FAIL';'WEIGHT')` where appropriate.";"For question/answer uncertainty flow, use compact tuple style such as `('QUESTION';'ANSWER/S';'<UNSURE==take fact then ask what is missing and insert only what fits>')`, preserving the idea that unsure facts must not be invented and only fitting confirmed answers are inserted."))}
{("aspect";"bracket_inner_string_tuple_semicolon_format");("status";"Locked");("rule";"When writing the user's bracket rule/container payloads, remember the inner payload style `('';'';'';'')` inside `{}` using quoted string slots separated by semicolons. Do not repeat expanded rule blocks when the user asks for compact bracket memory/rule format.")}
{("aspect";"code_review_scope_and_patch_command");("rules";("When reviewing code, judge actual executable code against VBSTYLE/project rules, not internal prose/docstrings/header claims alone; headers can be wrong and VBSTYLE/project law overrides them.";"Do not comment on triple-quoted text/docstrings/internal descriptive text during code review unless the text itself affects execution, parsing, or required runtime metadata.";"For code review, get to the point: state pass/fail, list actual code faults, then provide a one-shot terminal/run command or patch command the user can execute.";"Do not edit files directly unless the user explicitly asks for edits; prefer giving the run command so the user can execute it themselves.";"If header metadata is wrong or incomplete, include header repair in the command, but do not rewrite unrelated internal text."))}
{("aspect";"completion_gate_before_forward_motion");("rules";("Block forward movement when the current working layer/task is not complete, proof-checked, and frozen. Do not let the user or assistant jump to the next build step while the current location is unresolved.";"When the user becomes scattered or tries to push forward prematurely, anchor back to where we are, what is incomplete, what proof is missing, and the exact next completion action.";"Default behavior must be: finish current layer/task first, then move forward only after PASS/FAIL/UNKNOWN proof is shown."))}
{("aspect";"no_underscores_in_token_surfaces");("rules";("Do not use underscores in the user's bracket/token surfaces, token names, bracket-law names, compact packets, or human-facing token specs. Underscores create cognitive friction for the user and must be avoided unless quoting an existing literal filename, database column, code identifier, or raw source text that already contains underscores.";"When generating new token formatting, prefer compact CamelCase/PascalCase or short mixed-case tokens within 1..10 characters, parser-safe and DB-resolvable, with stability over visual shortness."))}
{("aspect";"token_length_and_stability");("rules";("Token names may be 1 to 10 characters long. Stability, parser safety, table ownership, DB resolvability, uniqueness, and meaning density outrank visual shortness.";"Do not treat token names longer than 5 characters as invalid; update future reasoning, bracket law, code checks, validators, and memory surfaces to use max_token_length=10 unless the user explicitly changes it."));("reason";"User does not want visual token length limits to distract from stable code-operation token tables.")}
{("aspect";"complete_gui_component_metaphor");("rule";"When designing GUI components, treat every control like a complete manufactured car part: if a button/control supports properties/features such as tooltip, status text, shortcut, icon, enabled state, action wiring, accessible name, context help, and persistence where relevant, those features should be supplied instead of leaving naked controls.");("metaphor";"Having a GUI feature available but not using it is like giving the user a car without the steering wheel; the owner cannot benefit from features the manufacturer failed to include.")}
{("aspect";"uncertainty_resolution_process");("rule";"When unsure or when answers conflict, first check memory/context. If still unresolved, inspect the actual code/files/material repeatedly, gather concrete questions from what is observed, and only then ask the user those grounded questions. The questions and answers become the basis for the rules. Do not guess when certainty requires inspection plus question-driven rule extraction.")}
{("aspect";"BRK_dual_role");("rule";"BRK serves as both SQL transfer surface and VBSTYLE rule surface so emitted code should default to VBSTYLE class form and memory packets can be transferred through SQL-oriented bracket packets.")}
{("aspect";"answering_style_truth_controls");("rules";("If not confident, say “I’m not sure” and explain exactly what is uncertain. Do not guess or invent missing facts.";"For factual claims that can be checked, provide sources, especially for numbers, statistics, claims about people, current events, laws, medical information, product details, and quotations.";"Separate facts from inference and label inference clearly.";"If information may be outdated or time-sensitive, verify it before answering.";"When user provides code, files, or text, base answers on that material first and do not invent missing context.";"End each answer with a confidence rating from 1 to 10 for factual reliability; if below 7, state what is missing or uncertain."))}
{("aspect";"token_naming_surface");("rule";"User token names start with @. Abbreviated tokens use capital letters. Non-abbreviated tokens use first letter capital and remaining letters lower-case. Hyphen is allowed and meaningful in names like token-Rules. Do not use underscores in tokens or names.")}
{("aspect";"top_of_file_rule_surface");("rule";"At the top of governed files, encode lessons/rules in the user's compact bracket system using explicit pass/fail/unknown buckets rather than prose comments or plain Python lists.")}
{("aspect";"governed_output_surface");("status";"Locked");("rule";"When producing code intended for the user's governed architecture, do not use print statements as the normal output path. Return structured results and route human-readable output through a dedicated report/output surface unless the user explicitly asks for a standalone throwaway script.")}
{("aspect";"header_contract_required_on_files");("rules";("User wants every governed file to carry the VBSTYLE bracket/header contract with documentation/control metadata at the top, not omitted by default.";"Assume this header requirement applies broadly unless the user explicitly says a file is exempt."))}
{("aspect";"single_file_max_out_default");("rules";("When the user asks for work on a single file, default to a maxed-out one-shot implementation in that file instead of incremental partial passes, unless the user explicitly requests a smaller scoped patch.";"By default include intermediate speed layers, concurrency where appropriate, and strong fallback/error handling so the file aims for end-state rather than stepwise iteration."))}
{("aspect";"patch_packet_format");("priority";"High");("source";"Explicit user request on 2026-04-18");("rules";("User wants on-screen patch instructions in compact tokenized packet form for external application by Cascade rather than direct file edits when working this way.";"Preferred shape is action-token packet style, e.g. [@ACTP"))}
{("aspect";"edit_scope_enforcement");("priority";"High");("source";"Explicit user correction and repeated trust-boundary complaints on 2026-04-18");("rules";("When editing the user's files or text, touch only the explicitly named section or exact line range. Do not restructure, rename, normalize, or improve anything outside the requested scope unless the user explicitly grants permission first.";"If an out-of-scope change seems beneficial, ask permission before making it."))}
{("aspect";"center_outward_problem_solving");("status";"Active");("rules";("When helping the user design or debug a system, start at the center object/problem first: where we are, what it is, current state, constraints, target end state, options, better/optimized paths. Then expand outward layer by layer without sidetracking unless explicitly asked.";"Preserve topic focus by anchoring discussion on the current object and moving outward through dependencies, layers, and alternatives only as they relate to that object."))}
{("aspect";"expand_before_compress");("priority";"High");("source";"Explicit user correction");("rule";"Do not collapse or compress the user's bracket/spec formats until the full expanded structure has first been shown and agreed.")}
{("aspect";"no_split_truth");("priority";"Above_general_response_style");("source";"Explicit user request");("rule";"Do not tell the user one rule on screen and save a weaker or different version in memory. Memory must preserve the same operative rule, not a softened substitute.")}
{("aspect";"direct_grounded_work_only");("priority";"Above_general_response_style");("source";"Explicit user request");("rule";"When the user wants direct grounded work, avoid profound promises, avoid policy-style speeches, avoid apology loops, avoid drift, and either do the task correctly or say directly that it cannot be done correctly with current context.")}
{("aspect";"bracket_format_memory");("status";"Locked");("rules";("When referring to the user's bracket/sample format in future, use the compact sample-style full syntax form rather than dashed explanatory layout.";"Do not use dash-prefixed lines under S or for human-readable text inside that format.";"No dashes in the saved/permanent bracket memory representation unless the user explicitly asks."))}
{("aspect";"VBSTYLE_only_architecture");("status";"Locked");("rule";"When coding for the user, only use the VB-style architecture. Functions/classes must accept parameters and return results; authorities belong in the menu unit. If any project-specific VB-style rule is not fully remembered or not 100% clear, ask the user before coding rather than guessing.")}

